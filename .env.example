# Environment Variables for ByteForge Frontend
# Copy to .env for local dev or .env.development for docker dev

# === Application ===
NODE_ENV=development
PORT=3000

# === Docker Compose ===
COMPOSE_PROJECT_NAME=byte-forge-frontend
APP_EXTERNAL_PORT=3000
DOCKER_BUILD_TARGET=development

# === API Configuration ===
VITE_API_BASE_URL=http://localhost:3005

# === Timeout Configuration (milliseconds) ===
VITE_CLIENT_TIMEOUT=30000
VITE_SERVER_TIMEOUT=10000

# === Public Shop API slices (mock fallback when false) ===
VITE_PUBLIC_SHOP_API_PROFILE=false
VITE_PUBLIC_SHOP_API_PRODUCTS=false
VITE_PUBLIC_SHOP_API_REVIEWS=false
